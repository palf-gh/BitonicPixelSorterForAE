#pragma kernel SortPass
// #pragma enable_d3d11_debug_symbols
// #pragma use_dxc // for nsight compatibility (D3D12 required)

#define MAX_THREADS 128 // threads per SM is usually multiple of 512 (NVIDIA). It may maximize occupancy.
#define MAX_SIZE 2048 // due to group shared memory limit

#define MAX_PAIRS (MAX_SIZE / MAX_THREADS / 2) // comparator pairs per thread

groupshared uint groupCache[MAX_SIZE];
groupshared uint scanCache[MAX_THREADS];

Texture2D<float4> srcTex;
RWTexture2D<float4> sortTex;

float thresholdMin;
float thresholdMax;
bool ordering;
bool direction;

float brightness(float4 col)
{
    return saturate(0.298912 * col.r + 0.586611 * col.g + 0.114478 * col.b);
}

[numthreads(MAX_THREADS,1,1)]
void SortPass(uint3 gid_l : SV_GroupID,
              uint3 gtid_l : SV_GroupThreadID)
{
    min16uint gid = gid_l.x;
    min16uint gtid = gtid_l.x;

    min16uint size;
    {
        min16uint width, height;
        sortTex.GetDimensions(width, height);

        size = direction ? width : height;
    }

    min16uint reducedSize = (size + 1) >> 1;
    min16uint ops = (reducedSize + MAX_THREADS - 1) / MAX_THREADS;
    min16uint pairBase = gtid * ops; // contiguous chunk of pairs per thread

    // load pixels: build sort keys and an in-threshold mask for this thread's chunk
    uint rangeMask = 0; // bit (2t): xL in threshold range, bit (2t+1): xR
    {
        for (uint t = 0; t < ops; t++)
        {
            min16uint xL = (pairBase + t) << 1;
            min16uint xR = xL + 1;

            uint2 posL;
            posL.x = direction ? xL : gid;
            posL.y = direction ? gid : xL;

            uint2 posR;
            posR.x = direction ? xR : gid;
            posR.y = direction ? gid : xR;

            float brL = brightness(srcTex[posL]);
            float brR = brightness(srcTex[posR]);

            bool inL = xL < size && thresholdMin <= brL && brL <= thresholdMax;
            bool inR = xR < size && thresholdMin <= brR && brR <= thresholdMax;

            rangeMask |= (inL ? 1u : 0u) << (t * 2);
            rangeMask |= (inR ? 1u : 0u) << (t * 2 + 1);

            // high 16bit for index, low 16bit for brightness
            groupCache[xL] = ((uint)xL << 16) | (f32tof16(brL) & 0xFFFF);
            groupCache[xR] = ((uint)xR << 16) | (f32tof16(brR) & 0xFFFF);
        }
    }

    uint preMeta[MAX_PAIRS];

    // forward pass: resolve the start index of the span containing each pair
    {
        // (last out-of-threshold index in this chunk) + 1, 0 if none
        uint seed = 0;
        for (uint t = 0; t < ops; t++)
        {
            uint xL = (uint)(pairBase + t) << 1;
            if (!(rangeMask & 1u << (t * 2))) seed = xL + 1;
            if (!(rangeMask & 2u << (t * 2))) seed = xL + 2;
        }

        scanCache[gtid] = seed;
        GroupMemoryBarrierWithGroupSync();

        // inclusive prefix-max scan across threads (Hillis-Steele)
        for (uint offset = 1; offset < MAX_THREADS; offset <<= 1)
        {
            uint own = scanCache[gtid];
            uint other = scanCache[max((uint)gtid, offset) - offset]; // clamped to keep the index valid
            GroupMemoryBarrierWithGroupSync();
            scanCache[gtid] = max(own, gtid >= offset ? other : 0);
            GroupMemoryBarrierWithGroupSync();
        }

        uint carry = scanCache[max((uint)gtid, 1u) - 1]; // exclusive prefix
        carry = gtid > 0 ? carry : 0;

        for (uint t = 0; t < ops; t++)
        {
            uint xL = (uint)(pairBase + t) << 1;
            bool inL = (rangeMask & 1u << (t * 2)) != 0;
            bool inR = (rangeMask & 2u << (t * 2)) != 0;

            uint start;
            if (inL)
            {
                start = carry; // span containing xL
            }
            else
            {
                carry = xL + 1;
                start = inR ? carry : xL; // span starting at xR, or a no-op pair
            }
            if (!inR) carry = xL + 2;

            preMeta[t] = start << 16;
        }

        GroupMemoryBarrierWithGroupSync(); // scanCache reads are done; safe to reuse below
    }

    uint lineLevels;

    // backward pass: resolve the end index of each span and the longest span in this line
    {
        // first out-of-threshold index in this chunk, 0xFFFF if none
        uint seed = 0xFFFF;
        for (uint t = ops; t > 0;)
        {
            t--;
            uint xL = (uint)(pairBase + t) << 1;
            if (!(rangeMask & 2u << (t * 2))) seed = xL + 1;
            if (!(rangeMask & 1u << (t * 2))) seed = xL;
        }

        scanCache[gtid] = seed;
        GroupMemoryBarrierWithGroupSync();

        // inclusive suffix-min scan across threads (Hillis-Steele)
        for (uint offset = 1; offset < MAX_THREADS; offset <<= 1)
        {
            uint own = scanCache[gtid];
            uint other = scanCache[min((uint)gtid + offset, MAX_THREADS - 1)]; // clamped to keep the index valid
            GroupMemoryBarrierWithGroupSync();
            scanCache[gtid] = min(own, (uint)gtid + offset < MAX_THREADS ? other : 0xFFFF);
            GroupMemoryBarrierWithGroupSync();
        }

        uint carry = scanCache[min((uint)gtid + 1, MAX_THREADS - 1)]; // exclusive suffix
        carry = (uint)gtid + 1 < MAX_THREADS ? carry : 0xFFFF;

        uint maxLen = 1;
        for (uint t = ops; t > 0;)
        {
            t--;
            uint xL = (uint)(pairBase + t) << 1;
            bool inL = (rangeMask & 1u << (t * 2)) != 0;
            bool inR = (rangeMask & 2u << (t * 2)) != 0;

            if (!inR) carry = xL + 1;

            uint start = preMeta[t] >> 16;
            uint end = inL || inR ? min(carry, (uint)size) - 1 : xL;

            if (!inL) carry = xL;

            // pairs whose comparator slot falls outside the span must not emit comparators
            // (they would race with the thread that owns the slot)
            uint xSlot = xL + (start & 1);
            bool valid = end > start && xSlot <= end;
            start = valid ? start : xSlot;
            end = valid ? end : xSlot;

            preMeta[t] = (start << 16) | end;
            maxLen = max(maxLen, end - start + 1);
        }

        GroupMemoryBarrierWithGroupSync(); // scanCache reads are done; safe to reuse below

        scanCache[gtid] = maxLen;
        GroupMemoryBarrierWithGroupSync();

        for (uint offset = MAX_THREADS >> 1; offset > 0; offset >>= 1)
        {
            if (gtid < offset) scanCache[gtid] = max(scanCache[gtid], scanCache[gtid + offset]);
            GroupMemoryBarrierWithGroupSync();
        }

        maxLen = scanCache[0];

        // just enough phases for the longest span. one extra merge phase for exact
        // power-of-two lengths so that every span ends up merged in the same direction
        lineLevels = maxLen <= 1 ? 0 : (uint)firstbithigh(maxLen) + 1;
    }

    for (uint phase = 0; (phase & 0xFFFF) < lineLevels; phase++)
    {
        for (phase = (phase << 16) + (phase & 0xFFFF); (uint)(phase >> 16) <= 0x7FFF; phase -= (1 << 16))
        {
            GroupMemoryBarrierWithGroupSync();

            for (uint t = 0; t < ops; t++)
            {
                uint metaPacked = preMeta[t];
                min16uint rangeStart = metaPacked >> 16;
                min16uint rangeEnd = metaPacked & 0xFFFF;

                min16uint x = (pairBase + t) << 1;

                min16uint useR = rangeStart & 1;
                min16uint posInRange = x - rangeStart + useR;
                min16uint swapIndex = posInRange >> 1;
                min16uint comparatorSize = 1 << (phase >> 16);
                min16uint a = rangeStart + (swapIndex & (comparatorSize - 1)) + floor(swapIndex >> (phase >> 16))
                    * (comparatorSize << 1);

                min16uint b = a + comparatorSize;

                b = b <= rangeEnd ? b : a;

                min16uint block = posInRange >> 1 >> phase;
                min16uint n = rangeEnd - rangeStart + 1;
                min16uint endBlock = n >> (phase + 1);
                bool ascPattern = ((endBlock & 1) == 0) == ordering;
                bool asc = ((block & 1) == 0) == ascPattern;

                // compare

                uint val_a = groupCache[a];
                uint val_b = groupCache[b];

                float br_a = f16tof32(val_a & 0xFFFF);
                float br_b = f16tof32(val_b & 0xFFFF);

                bool comp = br_a < br_b;

                uint left = asc == comp ? val_a : val_b;
                uint right = asc == comp ? val_b : val_a;

                groupCache[a] = left;
                groupCache[b] = right;
            }
        }
    }

    GroupMemoryBarrierWithGroupSync(); // make the last level's cross-thread swaps visible

    for (uint t = 0; t < ops; t++)
    {
        min16uint xL = (pairBase + t) << 1;
        min16uint xR = xL + 1;

        uint2 pos_a;
        pos_a.x = direction ? xL : gid;
        pos_a.y = direction ? gid : xL;

        uint2 pos_b;
        pos_b.x = direction ? xR : gid;
        pos_b.y = direction ? gid : xR;

        uint idx_left = groupCache[xL] >> 16;
        uint idx_right = groupCache[xR] >> 16;

        uint2 pos_left;
        pos_left.x = direction ? idx_left : gid;
        pos_left.y = direction ? gid : idx_left;

        uint2 pos_right;
        pos_right.x = direction ? idx_right : gid;
        pos_right.y = direction ? gid : idx_right;

        sortTex[pos_a] = srcTex[pos_left];
        sortTex[pos_b] = srcTex[pos_right];
    }
}
