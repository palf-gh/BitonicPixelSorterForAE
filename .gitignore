# BitonicPixelSorterForAE build and editor artefacts.

# CMake out-of-source build trees.
/build/
/build*/
/cmake-build-*/
/out/
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
/compile_commands.json

# Visual Studio / MSBuild local state.
/.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.VC.opendb
*.opensdf
*.ipch
*.tlog

# Xcode / macOS local state.
*.xcuserstate
xcuserdata/
DerivedData/
.DS_Store

# Compiler and linker intermediates.
*.obj
*.o
*.i
*.ii
*.pch
*.idb
*.ilk
*.pdb
*.exp
*.lib
*.lastbuildstate
*.metagen

# Generated shader and kernel intermediates outside release packages.
*.ptx
*.cubin
*.fatbin

# Keep Release plug-in deliverables versioned, but ignore non-release outputs.
/dist/Win/Debug/
/dist/Win/RelWithDebInfo/
/dist/Win/MinSizeRel/
/dist/Mac/Debug/
/dist/Mac/RelWithDebInfo/
/dist/Mac/MinSizeRel/
